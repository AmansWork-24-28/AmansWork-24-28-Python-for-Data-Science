import numpy as np

arr = np.array([1,2,5])
arr1 = np.array([1, 2, 3, 4, 5])
arr2 = np.array([2, 4, 6, 8, 10])


# mean
np.mean(arr)


# standard deviation
np.std(arr)



# variance
np.var(arr)


#  minimum
np.min(arr)



#  maximum
np.max(arr)




# Product of all elements
np.prod(arr)

# Median of the array
np.median(arr)

# Percentile of the array
np.percentile(arr, 50)

# Index of the minimum element
np.argmin(arr)

# Index of the maximum element
np.argmax(arr)

# Variance of the array
np.var(arr)

# Minimum element
np.min(arr)

# Maximum element
np.max(arr)

# Sum of all elements
np.sum(arr)

# Product of all elements
np.prod(arr)

# Median of the array
np.median(arr)

# 50th percentile (Median)
np.percentile(arr, 50)

# Index of the minimum element
np.argmin(arr)

# Correlation coefficient matrix
np.corrcoef(arr1, arr2)

# Unique elements
np.unique(arr)

# Difference between consecutive elements
np.diff(arr)

# Cumulative sum
np.cumsum(arr)

# Evenly spaced numbers in an interval
np.linspace(0, 10, 5)

# Natural logarithm
np.log(arr)

# Exponential (e^x)
np.exp(arr)






