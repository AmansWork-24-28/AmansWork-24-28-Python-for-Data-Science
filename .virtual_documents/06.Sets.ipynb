s.update([70, 80, 90])
print(s)
print()

#4. Remove an element (gives error if not present)
s.remove(20)
print(s)
print()

#5. Remove an element (no error if not present)
s.discard(100)
print(s)
print()

#6. Remove and return a random element
print(s.pop())
print(s)
print()

#7. Copy the set
s3 = s.copy()
